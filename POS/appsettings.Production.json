{
  "Serilog": {
    "MinimumLevel": { 
      "Default" : "Information",
       "Override": {
        "Microsoft": "Warning",
         "Microsoft.EntityFrameworkCore": "Warning"
       }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/POS-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/app/data/pos.db"
  },
  "LiteDb": {
    "ConnectionString": "Filename=/app/data/pos_temp.db;Connection=shared;"
  }
}
